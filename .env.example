# Copy this file to .env.local and fill in your values.
# See README.md for detailed instructions on obtaining each value.

# Neon Postgres (https://neon.tech)
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"
DATABASE_URL_DIRECT="postgresql://user:password@host-direct.neon.tech/dbname?sslmode=require"

# Vercel AI Gateway
AI_GATEWAY_API_KEY="your-ai-gateway-api-key"

# Vercel Blob (https://vercel.com/docs/storage/vercel-blob)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Admin API key (choose a strong random secret)
ADMIN_API_KEY="your-strong-admin-secret"

# Encryption key for AES-256-GCM (generate with: openssl rand -hex 32)
ENCRYPTION_KEY="64-hex-character-string-here"

# Previous encryption key for seamless rotation (optional)
# ENCRYPTION_KEY_PREVIOUS="old-64-hex-character-string"

# Composio MCP tool integrations (https://composio.dev)
# COMPOSIO_API_KEY="your-composio-api-key"

# GitHub API token for plugin marketplace access (5000 req/hr vs 60 unauthenticated)
# GITHUB_TOKEN="ghp_..."

# Vercel Cron authentication (auto-set by Vercel in production)
# CRON_SECRET="vercel-cron-secret"
